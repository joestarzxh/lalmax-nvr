{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.5.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "victoriametrics-logs-datasource",
      "name": "VictoriaLogs",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": [],
      "title": "VictoriaLogs \u2014 Frame Trace & Pipeline Events",
      "type": "row"
    },
    {
      "id": 2,
      "title": "Frame Trace Waterfall",
      "type": "logs",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "VictoriaLogs"
      },
      "description": "Recent frame pipeline events by trace_id. Filter by camera_id using the template variable. Set trace_id via the field filter to inspect a single frame's lifecycle.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "message:\"camera_id=$camera_id\" _time:15m | sort by (_time)"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "dedupStrategy": "none"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "IDR Drop Events",
      "type": "table",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "VictoriaLogs"
      },
      "description": "Count of StreamHub IDR frame drops by camera \u2014 indicates buffer-full events that lost a keyframe, likely causing downstream black screen.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 11
      },
      "targets": [
        {
          "refId": "A",
          "expr": "stage:=\"streamhub_drop\" is_idr:=\"true\" _time:1h | stats by (camera_id) count() as drops | sort by (drops desc)"
        }
      ],
      "transformations": [],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          },
          "displayName": "IDR Drops",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Error Events",
      "type": "logs",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "VictoriaLogs"
      },
      "description": "ERROR-level log events from the frame pipeline \u2014 HLS write errors, WebRTC drops, and other streaming failures.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 11
      },
      "targets": [
        {
          "refId": "A",
          "expr": "level:=\"ERROR\" stage:=\"hls_error\" OR stage:=\"webrtc_error\" OR stage:=\"streamhub_drop\" _time:1h | sort by (_time desc) | top 100 by (_time)"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "dedupStrategy": "none"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Reconnection Events (Frontend Telemetry)",
      "type": "logs",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "VictoriaLogs"
      },
      "description": "Frontend telemetry events from browser-side hls.js, FLV, and WebRTC players \u2014 segment load failures, buffer stalls, reconnection attempts, and stream degradation events.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "targets": [
        {
          "refId": "A",
          "expr": "component:=\"telemetry\" _time:1h | sort by (_time desc) | top 200 by (_time)"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "dedupStrategy": "none"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "id": 6,
      "panels": [],
      "title": "Prometheus \u2014 Camera Health & Stream Quality",
      "type": "row"
    },
    {
      "id": 7,
      "title": "Camera Connection Health",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Rate of camera connection errors by camera and error type (timeout, auth, network, unknown). Spikes indicate connectivity issues.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (camera_id, error_type) (rate(nvr_camera_connection_errors_total{camera_id=~\"$camera_id\"}[$__rate_interval]))",
          "legendFormat": "{{camera_id}} - {{error_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 8,
      "title": "Stream FPS",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Current frames per second for each camera stream.",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 12,
        "y": 28
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nvr_stream_fps{camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "green",
                "value": 15
              }
            ]
          },
          "min": 0,
          "max": 60
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 9,
      "title": "Stream Bitrate",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Current bitrate in kbps for each camera stream.",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 16,
        "y": 28
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nvr_stream_bitrate_kbps{camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kbps",
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 100
              },
              {
                "color": "green",
                "value": 500
              }
            ]
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 10,
      "title": "IDR Interval",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Seconds since last IDR (key) frame. High values indicate no IDR received, causing black screen for new/restarted players.",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 20,
        "y": 28
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nvr_stream_idr_interval_seconds{camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 11,
      "title": "End-to-End Frame Processing Latency",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Frame processing duration p50/p90/p99 quantiles by camera and protocol. Spikes indicate pipeline congestion.",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 36
      },
      "targets": [
        {
          "refId": "p50",
          "expr": "histogram_quantile(0.50, sum(rate(nvr_frame_processing_duration_seconds_bucket{camera_id=~\"$camera_id\"}[$__rate_interval])) by (le, camera_id, protocol))",
          "legendFormat": "p50 {{camera_id}} ({{protocol}})"
        },
        {
          "refId": "p90",
          "expr": "histogram_quantile(0.90, sum(rate(nvr_frame_processing_duration_seconds_bucket{camera_id=~\"$camera_id\"}[$__rate_interval])) by (le, camera_id, protocol))",
          "legendFormat": "p90 {{camera_id}} ({{protocol}})"
        },
        {
          "refId": "p99",
          "expr": "histogram_quantile(0.99, sum(rate(nvr_frame_processing_duration_seconds_bucket{camera_id=~\"$camera_id\"}[$__rate_interval])) by (le, camera_id, protocol))",
          "legendFormat": "p99 {{camera_id}} ({{protocol}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          },
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/p99/"
            },
            "properties": [
              {
                "id": "custom.lineWidth",
                "value": 2
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    5
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 12,
      "title": "Active HLS Sessions",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Number of active HLS streaming sessions per camera. Sudden drops may indicate connectivity issues or idle evictions.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 36
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nvr_hls_active_streams{camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 3
              },
              {
                "color": "red",
                "value": 4
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 13,
      "title": "WebRTC Connection States",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Distribution of WebRTC connection state changes (new/connecting/connected/disconnected/failed/closed). High failed/disconnected ratio indicates WebRTC instability.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 44
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (state) (increase(nvr_webrtc_connection_state_changes_total{camera_id=~\"$camera_id\"}[$__rate_interval]))",
          "legendFormat": "{{state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixed": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "disconnected"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixed": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "connected"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixed": "green"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "pieType": "pie",
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 14,
      "title": "HLS Segment Size Distribution",
      "type": "heatmap",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "HLS segment size distribution across buckets (64KB to 16MB). Unusually small or large segments may indicate encoding issues or corruption.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 44
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (le) (rate(nvr_hls_segment_size_bytes_bucket{camera_id=~\"$camera_id\"}[$__rate_interval]))",
          "legendFormat": "\u2264{{le}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "calculate": false,
        "cellGap": 1,
        "cellRadius": 1,
        "cellValues": {},
        "color": {
          "exponent": 0.5,
          "fill": "lightness",
          "mode": "opacity",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Oranges",
          "steps": 64
        },
        "exemplars": {
          "color": "rgba(255,0,255,0.7)"
        },
        "filterValues": {
          "le": 1e-09
        },
        "legend": {
          "showLegend": true
        },
        "rowsFrame": {
          "layout": "le"
        },
        "showValue": "never",
        "tooltip": {
          "mode": "multi"
        },
        "yAxis": {
          "axisPlacement": "left",
          "reverse": false,
          "unit": "bytes"
        }
      }
    },
    {
      "id": 15,
      "title": "FLV GOP Cache Misses",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Rate of FLV GOP cache misses per camera. Each miss means a new viewer must wait for the next IDR frame before playback can begin \u2014 high rate indicates frequent reconnections.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 44
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(nvr_flv_gop_cache_misses_total{camera_id=~\"$camera_id\"}[$__rate_interval])",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 16,
      "title": "Jitter Buffer Depth",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Current number of frames in each camera's jitter buffer. Sustained non-zero values indicate network jitter and out-of-order frame delivery.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 52
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nvr_jitter_buffer_depth{camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 3
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 17,
      "title": "StreamHub Frame Drop Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Rate of StreamHub frames dropped by camera and consumer (hls/flv/webrtc). Drops indicate buffer-full conditions \u2014 the primary cause of playback stutter and black frames.",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 52
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(nvr_streamhub_frames_dropped_total{camera_id=~\"$camera_id\"}[$__rate_interval])",
          "legendFormat": "{{camera_id}} - {{consumer}} (IDR={{is_idr}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/IDR=true/"
            },
            "properties": [
              {
                "id": "custom.lineWidth",
                "value": 2
              },
              {
                "id": "color",
                "value": {
                  "fixed": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
