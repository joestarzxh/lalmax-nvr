{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.5.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "victoriametrics-logs-datasource",
      "name": "VictoriaLogs",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": [],
      "title": "Camera Status",
      "type": "row"
    },
    {
      "id": 2,
      "title": "Active Cameras",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Total number of currently connected cameras. Red when zero, green when at least one camera is active.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nvr_active_cameras"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "sparkline": {
          "fillOpacity": 0.3,
          "lineWidth": 1
        }
      }
    },
    {
      "id": 3,
      "title": "Stream FPS per Camera",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Frames per second for each camera stream. Red below 5 FPS (unusable), yellow below 15 FPS (degraded). Normal operation is 25-30 FPS.",
      "gridPos": {
        "h": 8,
        "w": 10,
        "x": 4,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nvr_stream_fps{camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "max": 60,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "green",
                "value": 15
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 4,
      "title": "Stream Bitrate per Camera",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Current bitrate in kbps for each camera. Abnormal drops indicate encoder issues or stream disconnection.",
      "gridPos": {
        "h": 4,
        "w": 10,
        "x": 14,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nvr_stream_bitrate_kbps{camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kbps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "green",
                "value": 500
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 5,
      "title": "IDR Interval per Camera",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Seconds since the last IDR (key) frame. Yellow above 5s, red above 15s. High values cause black screens for new viewers and broken segment boundaries.",
      "gridPos": {
        "h": 4,
        "w": 10,
        "x": 14,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nvr_stream_idr_interval_seconds{camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 6,
      "panels": [],
      "title": "Connection Health",
      "type": "row"
    },
    {
      "id": 7,
      "title": "Camera Connection Error Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Rate of camera connection errors by type (timeout, auth, network, unknown). Spikes indicate connectivity issues \u2014 check network, credentials, or camera firmware.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (camera_id, error_type) (rate(nvr_camera_connection_errors_total{camera_id=~\"$camera_id\"}[5m]))",
          "legendFormat": "{{camera_id}} - {{error_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 8,
      "title": "Reconnection Attempts Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Rate of reconnection attempts per camera. High rates indicate unstable connections \u2014 the camera may be unreachable or credentials may be wrong.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (camera_id) (rate(nvr_camera_reconnect_attempts_total{camera_id=~\"$camera_id\"}[5m]))",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 9,
      "title": "Current Reconnect Backoff",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Current exponential backoff delay in seconds before the next reconnection attempt. Rising values indicate persistent connection failures. Resets on successful connection.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nvr_camera_reconnect_backoff_seconds{camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 30
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 10,
      "title": "Camera Error Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Rate of camera-level errors by type. Distinct from connection errors \u2014 these are operational errors (codec, pipeline, etc.).",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (camera_id, error_type) (rate(nvr_camera_errors_total{camera_id=~\"$camera_id\"}[5m]))",
          "legendFormat": "{{camera_id}} - {{error_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "id": 11,
      "panels": [],
      "title": "Xiaomi Camera",
      "type": "row"
    },
    {
      "id": 12,
      "title": "Xiaomi Disconnect Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Rate of Xiaomi CS2 P2P disconnect events by reason (network, eof, timeout). High rates indicate P2P tunnel instability or cloud service issues.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 23
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (camera_id, reason) (rate(nvr_xiaomi_disconnects_total{camera_id=~\"$camera_id\"}[5m]))",
          "legendFormat": "{{camera_id}} - {{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 13,
      "title": "Xiaomi Reconnect Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Rate of Xiaomi camera reconnection attempts. Should correlate with disconnect rate. High sustained rate indicates chronic P2P instability.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 23
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (camera_id) (rate(nvr_xiaomi_reconnects_total{camera_id=~\"$camera_id\"}[5m]))",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "id": 14,
      "panels": [],
      "title": "Frame Processing",
      "type": "row"
    },
    {
      "id": 15,
      "title": "Frame Processing Latency p50/p90/p99",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Frame processing duration percentiles by camera and protocol. Spikes indicate pipeline congestion or CPU pressure. p99 > 500ms causes visible stutter.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 30
      },
      "targets": [
        {
          "refId": "p50",
          "expr": "histogram_quantile(0.50, sum by (le, camera_id, protocol) (rate(nvr_frame_processing_duration_seconds_bucket{camera_id=~\"$camera_id\"}[5m])))",
          "legendFormat": "p50 {{camera_id}} ({{protocol}})"
        },
        {
          "refId": "p90",
          "expr": "histogram_quantile(0.90, sum by (le, camera_id, protocol) (rate(nvr_frame_processing_duration_seconds_bucket{camera_id=~\"$camera_id\"}[5m])))",
          "legendFormat": "p90 {{camera_id}} ({{protocol}})"
        },
        {
          "refId": "p99",
          "expr": "histogram_quantile(0.99, sum by (le, camera_id, protocol) (rate(nvr_frame_processing_duration_seconds_bucket{camera_id=~\"$camera_id\"}[5m])))",
          "legendFormat": "p99 {{camera_id}} ({{protocol}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/p99/"
            },
            "properties": [
              {
                "id": "custom.lineWidth",
                "value": 2
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    5
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 16,
      "title": "StreamHub Frame Drop Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Rate of frames dropped by StreamHub per camera and consumer type (hls/flv/webrtc). Drops indicate buffer-full conditions \u2014 the primary cause of playback stutter.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 30
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (camera_id, consumer) (rate(nvr_streamhub_frames_dropped_total{camera_id=~\"$camera_id\"}[5m]))",
          "legendFormat": "{{camera_id}} - {{consumer}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 17,
      "title": "StreamHub IDR Frame Drop Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "CRITICAL: Rate of IDR (keyframe) drops per camera. IDR drops cause black screens for all downstream viewers. Any non-zero rate is a serious problem requiring immediate investigation.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 36
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (camera_id) (rate(nvr_streamhub_frames_dropped_total{camera_id=~\"$camera_id\", is_idr=\"true\"}[5m]))",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 18,
      "title": "Ring Buffer Drops",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Rate of frame drops in the recorder ring buffer per camera. Indicates the recorder is not consuming frames fast enough \u2014 check disk I/O and CPU.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 36
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (camera_id) (rate(nvr_recorder_ring_buffer_drops_total{camera_id=~\"$camera_id\"}[5m]))",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
