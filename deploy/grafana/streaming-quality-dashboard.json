  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": [],
      "title": "Streaming Overview",
      "type": "row"
    },
    {
      "id": 2,
      "title": "Active HLS Streams",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Total number of active HLS streaming sessions. RPi 3B supports a maximum of 4 concurrent HLS streams.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(nvr_hls_active_streams{camera_id=~\"$camera_id\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 4
              }
            ]
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "sparkline": {
          "fillOpacity": 0.3,
          "lineWidth": 1
        }
      }
    },
    {
      "id": 3,
      "title": "Active WebRTC Peers",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Total number of active WebRTC peer connections. Each peer consumes CPU for RTP packetization.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(nvr_webrtc_active_peers{camera_id=~\"$camera_id\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "sparkline": {
          "fillOpacity": 0.3,
          "lineWidth": 1
        }
      }
    },
    {
      "id": 4,
      "title": "Active FLV Streams",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Total number of active HTTP-FLV streaming sessions. FLV provides low-latency playback in browsers without WebRTC support.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(nvr_flv_active_streams{camera_id=~\"$camera_id\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "sparkline": {
          "fillOpacity": 0.3,
          "lineWidth": 1
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 5,
      "panels": [],
      "title": "HLS Quality",
      "type": "row"
    },
    {
      "id": 6,
      "title": "HLS Active Streams per Camera",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Number of active HLS viewers per camera. Sudden drops may indicate connectivity issues or idle evictions.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nvr_hls_active_streams{camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 4
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 7,
      "title": "HLS Frame Drop Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Rate of frames dropped by the HLS muxer per camera. Dropped frames cause visible stuttering in the HLS player.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (camera_id) (rate(nvr_hls_frames_dropped_total{camera_id=~\"$camera_id\"}[5m]))",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 8,
      "title": "HLS Write Errors & Muxer Restarts",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Rate of HLS write errors and muxer restarts. Write errors indicate disk I/O issues; muxer restarts indicate corruption recovery.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(nvr_hls_write_errors_total[5m])",
          "legendFormat": "Write Errors"
        },
        {
          "refId": "B",
          "expr": "rate(nvr_hls_muxer_restarts_total[5m])",
          "legendFormat": "Muxer Restarts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 9,
      "title": "HLS Idle Evictions",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Rate of HLS muxers evicted due to idle timeout. Frequent evictions followed by re-creation waste CPU. May indicate keep-alive issues.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (camera_id) (rate(nvr_hls_idle_evictions_total{camera_id=~\"$camera_id\"}[5m]))",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 10,
      "title": "HLS Segment Size Distribution",
      "type": "heatmap",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "HLS segment size distribution across buckets (64KB to 16MB). Unusually small or large segments may indicate encoding issues or muxer corruption.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (le, camera_id) (rate(nvr_hls_segment_size_bytes_bucket{camera_id=~\"$camera_id\"}[5m]))",
          "legendFormat": "{{camera_id}} \u2264{{le}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "calculate": false,
        "cellGap": 1,
        "cellRadius": 1,
        "cellValues": {},
        "color": {
          "exponent": 0.5,
          "fill": "lightness",
          "mode": "opacity",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Oranges",
          "steps": 64
        },
        "exemplars": {
          "color": "rgba(255,0,255,0.7)"
        },
        "filterValues": {
          "le": 1e-09
        },
        "legend": {
          "showLegend": true
        },
        "rowsFrame": {
          "layout": "le"
        },
        "showValue": "never",
        "tooltip": {
          "mode": "multi"
        },
        "yAxis": {
          "axisPlacement": "left",
          "reverse": false,
          "unit": "bytes"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "id": 11,
      "panels": [],
      "title": "WebRTC Quality",
      "type": "row"
    },
