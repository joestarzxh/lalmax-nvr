    {
      "id": 18,
      "title": "FLV GOP Cache Hit/Miss Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Rate of GOP cache hits and misses per camera. Each miss means a new viewer must wait for the next IDR frame before playback begins. High miss rate indicates frequent new viewer connections.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 26
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (camera_id) (rate(nvr_flv_gop_cache_hits_total{camera_id=~\"$camera_id\"}[5m]))",
          "legendFormat": "{{camera_id}} hits"
        },
        {
          "refId": "B",
          "expr": "sum by (camera_id) (rate(nvr_flv_gop_cache_misses_total{camera_id=~\"$camera_id\"}[5m]))",
          "legendFormat": "{{camera_id}} misses"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
