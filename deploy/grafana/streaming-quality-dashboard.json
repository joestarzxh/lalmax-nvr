      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Number of active WebRTC peer connections per camera. Each peer requires CPU for RTP packetization and ICE handling.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 19
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nvr_webrtc_active_peers{camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}}"
        }
